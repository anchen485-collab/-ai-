# Optional. If omitted, the assistant still returns retrieval-based answers.
DASHSCOPE_API_KEY=

# Optional overrides.
KB_SOURCE_DIR=C:\Users\Administrator\Desktop\知识库
CHROMA_DIR=.\data\chroma
CHROMA_COLLECTION=qf_knowledge_base
LLM_MODEL=qwen-plus

# Deep Thinking Agent. OpenAI-compatible API settings.
# DeepSeek-R1 example:
# OPENAI_COMPATIBLE_API_KEY=sk-xxx
# OPENAI_COMPATIBLE_BASE_URL=https://api.deepseek.com
# DEEP_AGENT_MODEL=deepseek-reasoner
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=https://api.deepseek.com
DEEP_AGENT_MODEL=deepseek-reasoner
DEEP_AGENT_MAX_STEPS=8
DEEP_AGENT_TEMPERATURE=0.2
